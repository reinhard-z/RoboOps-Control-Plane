{
  "name": "@roboops/fleet-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:postgres": "tsx src/postgres-readiness-check.ts",
    "check:postgres:local": "tsx src/postgres-readiness-check.ts --local",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@roboops/fleet-domain": "workspace:*",
    "@roboops/fleet-persistence": "workspace:*",
    "@roboops/fleet-protocol": "workspace:*",
    "@roboops/observability": "workspace:*"
  }
}
